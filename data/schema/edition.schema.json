{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Documentation schema for OpenClaw Newspaper source-of-truth. Validation runtime lives in scripts/newspaper_data.py",
  "title": "Edition",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "projectId",
    "projectSlug",
    "slug",
    "fileName",
    "title",
    "rawTitle",
    "summary",
    "density",
    "densityLabel",
    "htmlUrl",
    "publishedAt",
    "size",
    "tags",
    "source"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2026-03-08.minimal-v1"
    },
    "kind": {
      "const": "Edition"
    },
    "id": {
      "type": "string"
    },
    "projectId": {
      "type": "string"
    },
    "projectSlug": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "fileName": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "rawTitle": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "density": {
      "enum": [
        "brief",
        "longform",
        "feature",
        "report",
        "note"
      ]
    },
    "densityLabel": {
      "type": "string"
    },
    "htmlUrl": {
      "type": "string"
    },
    "publishedAt": {
      "type": "string"
    },
    "size": {
      "type": "integer",
      "minimum": 0
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "object"
    }
  }
}
