{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Documentation schema for OpenClaw Newspaper source-of-truth. Validation runtime lives in scripts/newspaper_data.py",
  "title": "PublishRequest",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "project",
    "edition",
    "content",
    "source",
    "options"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2026-03-08.minimal-v1"
    },
    "kind": {
      "const": "PublishRequest"
    },
    "id": {
      "type": "string"
    },
    "project": {
      "type": "object"
    },
    "edition": {
      "type": "object"
    },
    "content": {
      "type": "object"
    },
    "source": {
      "type": "object"
    },
    "options": {
      "type": "object"
    }
  }
}
